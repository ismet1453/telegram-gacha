{
    "rewrites": [
        { "source": "/tonconnect-manifest.json", "destination": "/api/manifest" }
    ],
    "headers": [
        {
            "source": "/tonconnect-manifest.json",
            "headers": [
                { "key": "Access-Control-Allow-Origin", "value": "*" }
            ]
        },
        {
            "source": "/icon.png",
            "headers": [
                { "key": "Access-Control-Allow-Origin", "value": "*" }
            ]
        }
    ]
}
